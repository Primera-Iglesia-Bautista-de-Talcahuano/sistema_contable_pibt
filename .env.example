# Supabase (run `pnpm supabase:status` to get these values for local dev)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."

# Google Apps Script integrations (optional — PDF, Sheets sync, email via GAS)
GOOGLE_APPS_SCRIPT_WEBHOOK_URL="https://script.google.com/macros/s/<script_hash>/exec"
GOOGLE_APPS_SCRIPT_SECRET=""

# Email notifications via Resend (https://resend.com)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Sistema contable PIBT <noreply@pibt.com>"
# Optional: recipient address. If not set, email sending is skipped.
NOTIFICATION_EMAIL="john.doe@mail.com"
