@import "tailwindcss";

@theme inline {
  --color-background: #f7f9fb;
  --color-error: #ba1a1a;
  --color-error-container: #ffdad6;
  --color-inverse-on-surface: #eff1f3;
  --color-inverse-primary: #6bd8cb;
  --color-inverse-surface: #2d3133;
  --color-on-background: #191c1e;
  --color-on-error: #ffffff;
  --color-on-error-container: #93000a;
  --color-on-primary: #ffffff;
  --color-on-primary-container: #f4fffc;
  --color-on-primary-fixed: #00201d;
  --color-on-primary-fixed-variant: #005049;
  --color-on-secondary: #ffffff;
  --color-on-secondary-container: #54647a;
  --color-on-secondary-fixed: #0b1c30;
  --color-on-secondary-fixed-variant: #38485d;
  --color-on-surface: #191c1e;
  --color-on-surface-variant: #3d4947;
  --color-on-tertiary: #ffffff;
  --color-on-tertiary-container: #fffbff;
  --color-on-tertiary-fixed: #370e00;
  --color-on-tertiary-fixed-variant: #773215;
  --color-outline: #6d7a77;
  --color-outline-variant: #bcc9c6;
  --color-primary: #00685f;
  --color-primary-container: #008378;
  --color-primary-fixed: #89f5e7;
  --color-primary-fixed-dim: #6bd8cb;
  --color-secondary: #505f76;
  --color-secondary-container: #d0e1fb;
  --color-secondary-fixed: #d3e4fe;
  --color-secondary-fixed-dim: #b7c8e1;
  --color-surface: #f7f9fb;
  --color-surface-bright: #f7f9fb;
  --color-surface-container: #eceef0;
  --color-surface-container-high: #e6e8ea;
  --color-surface-container-highest: #e0e3e5;
  --color-surface-container-low: #f2f4f6;
  --color-surface-container-lowest: #ffffff;
  --color-surface-dim: #d8dadc;
  --color-surface-tint: #006a61;
  --color-surface-variant: #e0e3e5;
  --color-tertiary: #924628;
  --color-tertiary-container: #b05e3d;
  --color-tertiary-fixed: #ffdbce;
  --color-tertiary-fixed-dim: #ffb59a;

  --font-sans: var(--font-manrope);
}

@layer base {
  body {
    background-color: var(--color-background);
    color: var(--color-on-background);
    font-family: var(--font-sans), sans-serif;
  }
}

